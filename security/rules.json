{
  "rules": {
    ".read":  "auth != null",
    ".write": "false",

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin'",
        "role": {
          ".validate": "newData.isString() && newData.val().matches(/^(admin|solar|wtg|bop|viewer)$/)"
        },
        "name":  { ".validate": "newData.isString() && newData.val().length < 80" },
        "email": { ".validate": "newData.isString() && newData.val().length < 120" }
      }
    },

    "solar": {
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'solar')",
      "itcs": {
        "$itcId": {
          "acts": {
            "$idx": {
              "done":   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
              "today":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
              "lastBy": { ".validate": "newData.val() === auth.uid" },
              "lastAt": { ".validate": "newData.val() <= now + 60000" }
            }
          }
        }
      }
    },

    "wtg": {
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'wtg')",
      "turbines": {
        "$turbId": {
          "lastBy": { ".validate": "newData.val() === auth.uid" },
          "lastAt": { ".validate": "newData.val() <= now + 60000" }
        }
      }
    },

    "bop": {
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'bop')"
    },

    "land": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "hse": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer'",
      "observations": {
        "$id": {
          ".validate": "newData.hasChildren(['type','desc','by','ts'])",
          "by": { ".validate": "newData.val() === auth.uid" },
          "ts": { ".validate": "newData.val() <= now + 60000" }
        }
      }
    },

    "pod": {
      "$date": {
        ".validate": "$date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)",
        "$pushId": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer'",
          ".validate": "newData.hasChildren(['module','activity','by','ts'])",
          "module":   { ".validate": "newData.isString() && newData.val().matches(/^(s|w|l|b)$/)" },
          "activity": { ".validate": "newData.isString() && newData.val().length < 200" },
          "by":       { ".validate": "newData.val() === auth.uid" },
          "ts":       { ".validate": "newData.val() <= now + 60000" },
          "qty":      { ".validate": "newData.isNumber()" },
          "mp":       { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < 10000" }
        }
      }
    },

    "milestones": {
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'solar' || root.child('users').child(auth.uid).child('role').val() === 'wtg' || root.child('users').child(auth.uid).child('role').val() === 'bop')",
      "$id": {
        ".validate": "newData.hasChildren(['title','date','by','ts'])",
        "title": { ".validate": "newData.isString() && newData.val().length < 200" },
        "date":  { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)" },
        "by":    { ".validate": "newData.val() === auth.uid" },
        "ts":    { ".validate": "newData.val() <= now + 60000" }
      }
    },

    "rowIssues": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer'",
      "$id": {
        "loc":    { ".validate": "newData.isString() && newData.val().length < 100" },
        "issue":  { ".validate": "newData.isString() && newData.val().length < 500" },
        "type":   { ".validate": "newData.isString() && newData.val().matches(/^(WTG|Solar|BOP|Other)$/)" },
        "status": { ".validate": "newData.isString() && newData.val().matches(/^(Open|Closed|In Progress)$/)" },
        "ts":     { ".validate": "newData.val() <= now + 60000" }
      }
    },

    "ganttRows": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "dailyProgress": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer'",
      "$id": {
        "by": { ".validate": "newData.val() === auth.uid" },
        "ts": { ".validate": "newData.val() <= now + 60000" }
      }
    },

    "blockers": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer'"
    },

    "schedule": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "audit": {
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$ts": {
        ".write":    "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['uid','path','action','ts'])"
      }
    }
  }
}

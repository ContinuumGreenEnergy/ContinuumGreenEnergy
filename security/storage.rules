rules_version = '2';

// Apply these in: Firebase Console → Storage → Rules → Edit → Publish.
//
// Reads are public — the dashboard itself is public, so anyone visiting
// the site needs to be able to render the HSE / ITC / POD photos.
//
// IMPORTANT: this app uses a demo password gate (js/auth.js), NOT Firebase
// Authentication — firebase-auth-compat.js is intentionally not loaded, so
// request.auth is ALWAYS null at runtime. Writes are therefore permitted
// without auth, but every write is hard-capped server-side at 5 MB and
// image/* MIME types so a malicious script can't abuse free-tier storage.
// If you later adopt Firebase Auth (incl. anonymous auth), tighten the
// write rules back to `request.auth != null && …`.
service firebase.storage {
  match /b/{bucket}/o {

    match /hse/{date}/{file} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /itc/{itcId}/maps/{file} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /pod/{date}/{file} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /subphotos/{module}/{ownerId}/{file} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default-deny anything outside the named prefixes above.
    match /{anyPath=**} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
